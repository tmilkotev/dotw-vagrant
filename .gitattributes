# Force LF for shell scripts
*.sh text eol=lf

# Force LF for provisioning, configs, infra
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.env text eol=lf

# Windows scripts stay CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Vagrant / Ruby files
Vagrantfile text eol=lf
*.rb text eol=lf

# Default behavior
* text=auto